<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Document</title>
    </head>
    <body>
        <h1><%= pageTitle %></h1>
<% if (students.length > 0) { %>
<table border="1">
<thead>
<tr>
<th>ID</th>
<th>Name</th>
<th>Grade</th>
</tr>
</thead>
<tbody>
<% students.forEach(function(student) { %>
<tr>
<td><%= student.id %></td>
<td><%= student.name %></td>
<td><%= student.grade %></td>
</tr>

<% }); %>
</tbody>
</table>
<% } else { %>
<p>No students found</p>
<% } %>
    </body>
</html>


